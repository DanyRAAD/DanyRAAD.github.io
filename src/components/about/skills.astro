<section class="site-container mt-14 mx-auto max-w-6xl px-4">
  <div class="site-container mt-14">
    <h2
      class="text-4xl font-bold flex flex-col items-center gap-6 text-center whitespace-nowrap text-white md:flex-row md:items-center md:text-start"
    >
      <span class="drop-shadow-[2px_2px_0_#7836cf]">Tools & Technologies</span>
      <span
        class="hidden h-1.5 grow rounded-lg drop-shadow-[2px_2px_0_#0debd8] bg-[#7836cf] md:block"
      ></span>
    </h2>
  </div>

  <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">
    {
      [
        { name: "Unity", icon: "/icons/unity_gris.svg" },
        { name: "C#", icon: "/icons/csharp.svg" },
        { name: "Blender", icon: "/icons/blender.svg" },
        { name: "Maya", icon: "/icons/maya.svg" },
        { name: "3ds Max", icon: "/icons/3dsmax.svg" },
        { name: "ZBrush", icon: "/icons/zbrush.svg" },
        { name: "Marvelous Designer", icon: "/icons/marvelous.svg" },
        { name: "Substance Painter", icon: "/icons/substance.svg" },
        { name: "Git", icon: "/icons/git.svg" },
        { name: "GitHub", icon: "/icons/github_color.svg" },
      ].map((skill) => (
        <div class="relative group">
          <div class="absolute inset-0 -z-10 rounded-lg blur-3xl opacity-0 transition-opacity group-hover:opacity-100"></div>

          <div class="flex flex-col items-center bg-gray-900 p-4 rounded-lg shadow-md drop-shadow-[4px_4px_0_#7836cf] transition-transform duration-300 hover:scale-105">
            <img
              src={skill.icon}
              alt={skill.name}
              class="w-12 h-12 object-contain"
            />

            <p class="mt-2 text-white text-lg font-semibold text-center drop-shadow-[1px_1px_0_#7836cf]">
              {skill.name}
            </p>
          </div>
        </div>
      ))
    }
  </div>
</section>